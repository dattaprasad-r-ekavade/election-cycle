; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Election Cycle"
config/description="A satirical political RPG where you have 7 in-game days to win an election."
run/main_scene="res://scenes/main_menu.tscn"
config/features=PackedStringArray("4.4", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

GameManager="*res://systems/game_manager.gd"
SkillSystem="*res://systems/skill_system.gd"
PerkSystem="*res://systems/perk_system.gd"
DialogueSystem="*res://systems/dialogue_system.gd"
NewsSystem="*res://systems/news_system.gd"
ContentLoader="*res://systems/content_loader.gd"
DiceRollSystem="*res://systems/dice_roll_system.gd"
DebugOverlay="*res://systems/debug_overlay.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"

[input]

ui_accept={
"deadzone": 0.5,
